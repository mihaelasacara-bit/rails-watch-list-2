<div class="container">
  <h1 class="page-title mt-3"> Lists index </h1>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% @lists.each do |list| %>
      <div class="col">
        <div class="list-card h-100 d-flex flex-column">
          <div class="list-img" style="background-image: url(<%= list.movies.empty? ? "https://images.unsplash.com/photo-1518676590629-3dcbd9c5a5c9?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" : list.movie.first.poster_url %>)"></div>
          <div class="list-card-body">
            <h1><%= list.name %></h1>
          </div>
          <div class="list-card-bottom d-flex justify-content-between mt-auto">
            <%= link_to list_path(list), class: "view-btn btn btn-outline-dark" do %>
            <i class="fa-regular fa-circle-play"></i> VIEW LIST
            <% end %>
          </div>
        </div>
      </div>
      <% end%>
    </div>
</div>
